# Copy this file to ".env" and fill in your keys.
# NOTE: VITE_ vars are exposed in the browser bundle — fine for a demo,
# use a backend proxy for production.

# Sarvam AI — used for BOTH Speech-to-Text and Text-to-Speech.
# Get it from https://dashboard.sarvam.ai
VITE_SARVAM_API_KEY=

# Lyzr AI Agent — the agricultural assistant agent.
# Get these from https://studio.lyzr.ai
VITE_LYZR_API_KEY=
VITE_LYZR_AGENT_ID=
# The user id Lyzr associates the session with (any stable string / email).
VITE_LYZR_USER_ID=demo@farmer.app
